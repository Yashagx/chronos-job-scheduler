# Chronos — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://chronos:CHANGE_ME@postgres:5432/chronos?schema=public"
POSTGRES_USER=chronos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=chronos

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://:CHANGE_ME@redis:6379"
REDIS_PASSWORD=CHANGE_ME

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API Service ─────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Worker Service ──────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_HEARTBEAT_TTL_SECONDS=30
WORKER_SCHEDULER_TICK_MS=5000
WORKER_CONCURRENCY=5

# ─── Web (Next.js) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
